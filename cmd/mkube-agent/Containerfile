# Agent container — talks to host podman via socket, git runs inside build containers
FROM fedora:latest
RUN mkdir -p /var/stormd/logs /data
COPY stormd /stormd
COPY mkube-agent /app/mkube-agent
COPY config.toml /etc/stormd/config.toml
VOLUME ["/data"]
EXPOSE 9080 8080 22
ENTRYPOINT ["/stormd"]
CMD ["--config", "/etc/stormd/config.toml"]
