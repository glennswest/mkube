# Multi-stage: grab stormd from stormdbase
FROM registry.gt.lo:5000/stormdbase:latest AS stormd

# Agent container — needs podman + git to run build containers
FROM fedora:rawhide
RUN dnf install -y podman git && dnf clean all
# Use native overlay (not fuse-overlayfs) — container runs --privileged
RUN mkdir -p /etc/containers && \
    echo '[storage]' > /etc/containers/storage.conf && \
    echo 'driver = "overlay"' >> /etc/containers/storage.conf && \
    echo '[storage.options.overlay]' >> /etc/containers/storage.conf && \
    echo 'mount_program = ""' >> /etc/containers/storage.conf
RUN mkdir -p /var/stormd/logs /data
COPY --from=stormd /stormd /stormd
COPY mkube-agent /app/mkube-agent
COPY config.toml /etc/stormd/config.toml
VOLUME ["/data"]
EXPOSE 9080 8080 22
ENTRYPOINT ["/stormd"]
CMD ["--config", "/etc/stormd/config.toml"]
