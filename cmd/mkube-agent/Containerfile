# Agent container — uses host podman via socket, only needs git for log commits
FROM fedora:rawhide
RUN dnf install -y git && dnf clean all
RUN mkdir -p /var/stormd/logs /data
COPY stormd /stormd
COPY mkube-agent /app/mkube-agent
COPY config.toml /etc/stormd/config.toml
VOLUME ["/data"]
EXPOSE 9080 8080 22
ENTRYPOINT ["/stormd"]
CMD ["--config", "/etc/stormd/config.toml"]
